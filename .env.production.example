# Bifrost — production environment template.
#
# Copy to .env.production and fill in real values. Required vars are marked
# REQUIRED. Boot will fail (entrypoint exit 78) if a required value is missing
# or invalid — see backend/app/scripts/validate_env.py for the rules.

# ----- core ---------------------------------------------------------------
ENVIRONMENT=production
PROJECT_NAME=Bifrost
API_V1_PREFIX=/api/v1

# ----- database (REQUIRED) -------------------------------------------------
DATABASE_URL=postgresql+psycopg://bifrost:CHANGE_ME@postgres:5432/bifrost
POSTGRES_USER=bifrost
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=bifrost

# ----- auth (REQUIRED) -----------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
AUTH_ENFORCEMENT_ENABLED=false

# ----- cors ----------------------------------------------------------------
# Comma-separated list. No wildcards in production.
CORS_ORIGINS=https://bifrost.example.com

# ----- realtime (optional, recommended for multi-worker) -------------------
REDIS_URL=redis://redis:6379/0

# ----- observability (optional) --------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
OTEL_SERVICE_NAME=bifrost-backend
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ----- rate limiting -------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=600
RATE_LIMIT_BURST=120

# ----- governance ----------------------------------------------------------
GOVERNANCE_AUTONOMY_CONFIDENCE_FLOOR=0.65
GOVERNANCE_MAX_PROPOSALS_PER_MISSION_PER_HOUR=20

# ----- migration ownership -------------------------------------------------
# Leave 0 on app pods; set 1 on a single migrator job/pod.
BIFROST_RUN_MIGRATIONS=0
BIFROST_WAIT_FOR_DB=1
BIFROST_WAIT_FOR_DB_TIMEOUT=60

# ----- frontend (Next.js) --------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=https://bifrost.example.com/api/v1
