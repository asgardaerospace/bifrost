# Bifrost frontend — environment variables
#
# Base URL of the Bifrost backend API (including /api/v1 suffix).
# Local development (with the backend running on port 8000):
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# Production (Vercel):
#   NEXT_PUBLIC_API_BASE_URL=https://api.bifrost.asgardaerospace.com/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
